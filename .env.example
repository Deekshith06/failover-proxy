# ─── Required ────────────────────────────────────────────────────────────────
# Comma-separated OpenRouter API keys
OPENROUTER_KEYS=YOUR_OPENROUTER_KEY_1,YOUR_OPENROUTER_KEY_2

# ─── Optional: VibeProxy (primary provider if configured) ────────────────────
# VIBEPROXY_BASE_URL=https://your-vibeproxy.example.com
# VIBEPROXY_API_KEY=your-vibeproxy-key
# VIBEPROXY_KEYS=key1,key2

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=9000
LOG_LEVEL=info

# ─── Timeouts & Limits ───────────────────────────────────────────────────────
REQUEST_TIMEOUT_MS=30000
COOLDOWN_MS=30000
MAX_COOLDOWN_MS=300000
USAGE_CACHE_MS=15000
MAX_BODY_BYTES=10485760
MAX_RETRIES=10
BODY_TIMEOUT_MS=30000
SHUTDOWN_GRACE_PERIOD_MS=10000

# ─── Model Filtering ─────────────────────────────────────────────────────────
# Regex to filter models from /v1/models endpoint (case-insensitive)
MODEL_FILTER_REGEX=claude
